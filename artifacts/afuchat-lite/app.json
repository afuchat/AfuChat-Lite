{
  "expo": {
    "name": "AfuChat Lite",
    "slug": "afuchat-lite",
    "owner": "afunew",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "afuchat-lite",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/images/logo.png",
      "resizeMode": "contain",
      "backgroundColor": "#FFFFFF"
    },
    "android": {
      "package": "com.afuchat.lite",
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/icon.png",
        "backgroundColor": "#1E90FF"
      },
      "notification": {
        "icon": "./assets/images/logo.png",
        "color": "#1E90FF"
      },
      "splash": {
        "image": "./assets/images/logo.png",
        "resizeMode": "contain",
        "backgroundColor": "#FFFFFF",
        "dark": {
          "image": "./assets/images/logo.png",
          "resizeMode": "contain",
          "backgroundColor": "#06090F"
        }
      }
    },
    "plugins": [
      "expo-router",
      "expo-font",
      "expo-web-browser"
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    },
    "extra": {
      "eas": {
        "projectId": "8b198c70-5a6d-42eb-b175-71d128fed50e"
      }
    }
  }
}
